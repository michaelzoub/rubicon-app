# Public app URL
NEXT_PUBLIC_APP_URL=https://app.rubiconpay.xyz
NEXT_PUBLIC_RUBICON_HOME_URL=https://rubiconpay.xyz

# Creator authentication
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=
SUPABASE_JWT_SECRET=

# Rubicon gateway/API
NEXT_PUBLIC_RUBICON_API_BASE=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Semantic-search embeddings (write side of the gateway's embeddings contract).
# On publish/edit/unpublish the server writes per-section vectors to
# article_section_embeddings using the service-role key above. When unset, the
# index simply isn't updated and the gateway falls back to lexical search.
OPENAI_API_KEY=

# Optional onchain RPC override
ARC_RPC_URL=
CIRCLE_GATEWAY_API_URL=

# Optional dashboard docs examples
CIRCLE_AGENT_WALLET_ADDRESS=
RUBICON_AGENT_API_KEY=
RUBICON_GATEWAY_URL=

# Optional analytics
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=

# Optional X (Twitter) import — onboarding search + article listing.
# Exact @handle lookup works without credentials. Broader name search and
# profile-wide Article listing are login-gated by X; set X_COOKIE to a logged-in
# session (must contain auth_token and ct0) to enable them. X_AUTH_BEARER
# overrides the default web bearer. Pasting one X article URL needs neither.
X_AUTH_BEARER=
X_COOKIE=
